generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @default(autoincrement()) @id
  email String?  
  name  String  @unique
  password String
}

model Abecedari_abc {
  id        Int      @default(autoincrement()) @id
  lletres   String
  abecedariId Int
}

model Abecedari_abc_lletres {
  id          Int      @default(autoincrement()) @id
  lletres     String
  lletres_blue String
  voice_mp3   String
  abecedariId Int
}
